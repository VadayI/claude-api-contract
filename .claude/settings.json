{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git tag:*)",
      "Bash(gh pr:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(gh release:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(oasdiff:*)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push --force:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(.claude/settings.local.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/credentials*)",
      "Read(secrets/**)"
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/policy/block_protected_edits.sh",
            "statusMessage": "Checking protected-file edit policy..."
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "release|ship-contract|create-pr",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/policy/check_command_gate.sh",
            "statusMessage": "Checking command preconditions..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "ba|api-architect|tsp-author|contract-reviewer|breaking-change-analyst|mock-validator|docs-writer|happy-path-author",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/policy/check_plan_execution_log.sh",
            "statusMessage": "Checking living-plan execution log..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx --no-install tsp format \"spec/**/*.tsp\" 2>/dev/null || true",
            "statusMessage": "Formatting TypeSpec (tsp format)..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-start.sh",
            "statusMessage": "Detecting environment..."
          }
        ]
      }
    ]
  },
  "_last_reviewed": "2026-06-06"
}
