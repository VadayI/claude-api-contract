# ── claude-api-contract — local environment (copy to .env; .env is gitignored) ──

# GitHub access (never commit real values). Fine-grained PAT recommended (ADR 0008-style).
GITHUB_PERSONAL_ACCESS_TOKEN=

# Context7 MCP (library docs lookups) — optional but recommended.
CONTEXT7_API_KEY=

# Prism mock server (defaults are fine for local dev).
PRISM_PORT=4010

# Release / consumer pinning (informational; the canonical source is git tags).
CONTRACT_REPO=https://github.com/VadayI/claude-api-contract
